-- =================================================================
-- GoldenGate 19c Extract: {{ group.extract_name }}
-- Tables: {{ group.table_count }}  Schemas: {{ group.schemas | join(', ') }}
-- Generated by: python3 -m app.main generate
-- =================================================================

EXTRACT {{ group.extract_name }}
USERIDALIAS {{ source_alias }}

{% if encryption_enabled -%}
-- Encrypt trail files at rest (AES256)
ENCRYPTTRAIL {{ encryption_algorithm }}, KEYNAME {{ encryption_keyname }}
{% endif -%}
EXTTRAIL {{ trail_dir }}/{{ group.extract_trail }}

NOCOMPRESSUPDATES
NOCOMPRESSDELETES
GETUPDATEBEFORES

-- Monitoring: report every 30 minutes (rows processed)
REPORTCOUNT EVERY 30 MINUTES, RATE

-- Warn on long-running transactions (helps debug lag)
WARNLONGTRANS 15M, CHECKINTERVAL 5M

-- Table list
{% for t in group.tables %}
TABLE {{ t.schema }}.{{ t.name }};
{% endfor %}
