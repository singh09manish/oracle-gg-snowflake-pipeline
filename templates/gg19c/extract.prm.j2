-- =================================================================
-- GoldenGate 19c Integrated Extract: {{ group.extract_name }}
-- Tables: {{ group.table_count }}  Schemas: {{ group.schemas | join(', ') }}
-- Generated by: python3 -m app.main generate
-- =================================================================

EXTRACT {{ group.extract_name }}
SETENV (NLS_LANG = "AMERICAN_AMERICA.AL32UTF8")

-- Credential store alias
USERIDALIAS {{ source_alias }}

-- Integrated extract: Oracle RDS logmining server
-- max_sga_size: {{ sga_size_mb }} MB for {{ group.table_count }} tables
-- parallelism: {{ parallelism }} prep threads
TRANLOGOPTIONS INTEGRATEDPARAMS (max_sga_size {{ sga_size_mb }}, parallelism {{ parallelism }})

-- Exclude GG extract user's own DML (prevent capture loop)
TRANLOGOPTIONS EXCLUDEUSER {{ exclude_user }}

-- Capture all supplemental columns for correct MERGE on target
LOGALLSUPCOLS

-- Only PK + changed columns in UPDATE trail records (30-50% trail reduction)
UPDATERECORDFORMAT COMPACT

-- Fetch LOB columns and compressed rows from source on demand
FETCHOPTIONS FETCHPKUPDATECOLS

-- Report progress every minute
REPORTCOUNT EVERY 1 MINUTES, RATE

{% if encryption_enabled -%}
-- AES256 encrypted trail files
ENCRYPTTRAIL {{ encryption_algorithm }}, KEYNAME {{ encryption_keyname }}
{% endif -%}
EXTTRAIL {{ trail_dir }}/{{ group.extract_trail }}, MEGABYTES {{ trail_size_mb }}

-- Discard file for rows that fail to capture (PK issues, etc.)
DISCARDFILE ./dirrpt/{{ group.extract_name }}_discard.txt, APPEND, MEGABYTES 100

-- -----------------------------------------------------------------
-- TABLE rules ({{ group.table_count }} tables)
-- -----------------------------------------------------------------
{% for t in group.tables %}
TABLE {{ t.schema }}.{{ t.name }};
{% endfor %}
