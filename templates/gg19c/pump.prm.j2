-- =================================================================
-- GoldenGate 19c Data Pump: {{ group.pump_name }}
-- Pass-through delivery to GG BigData 21c (port {{ target_mgr_port }})
-- Tables: {{ group.table_count }}
-- Generated by: python3 -m app.main generate
-- =================================================================

EXTRACT {{ group.pump_name }}

-- PASSTHRU: zero transformation, maximum throughput
PASSTHRU

-- Report progress every minute
REPORTCOUNT EVERY 1 MINUTES, RATE

-- Deliver to GG BigData 21c Manager (same EC2)
RMTHOST {{ target_host }}, MGRPORT {{ target_mgr_port }}, COMPRESS

-- Pump trail read by GG 21c Replicat
RMTTRAIL {{ target_trail_dir }}/{{ group.pump_trail }}, MEGABYTES {{ trail_size_mb }}

-- -----------------------------------------------------------------
-- TABLE rules (must mirror extract)
-- -----------------------------------------------------------------
{% for t in group.tables %}
TABLE {{ t.schema }}.{{ t.name }};
{% endfor %}
