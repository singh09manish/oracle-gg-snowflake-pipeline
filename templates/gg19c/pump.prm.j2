-- =================================================================
-- GoldenGate 19c Data Pump: {{ group.pump_name }}
-- Pass-through delivery to GG BigData 21c (port {{ target_mgr_port }})
-- Tables: {{ group.table_count }}
-- Generated by: python3 -m app.main generate
-- =================================================================

EXTRACT {{ group.pump_name }}

{% if encryption_enabled -%}
-- Decrypt incoming encrypted trail
DECRYPTTRAIL {{ encryption_algorithm }}
-- Encrypt remote trail written to GG 21c
ENCRYPTTRAIL {{ encryption_algorithm }}, KEYNAME {{ encryption_keyname }}
{% endif -%}

-- Send to GG 21c on same server, port {{ target_mgr_port }}
{% if encrypt_rmthost -%}
RMTHOST {{ target_host }}, MGRPORT {{ target_mgr_port }}, ENCRYPT AES256
{% else -%}
RMTHOST {{ target_host }}, MGRPORT {{ target_mgr_port }}
{% endif -%}
RMTTRAIL {{ target_trail_dir }}/{{ group.pump_trail }}
PASSTHRU

-- Performance
DYNAMICRESOLUTION
NUMFILES 1000

-- Monitoring
REPORTCOUNT EVERY 30 MINUTES, RATE
WARNLONGTRANS 2H, CHECKINTERVAL 30M

-- Pass through schemas
{% for schema in group.schemas %}
TABLE {{ schema }}.*;
{% endfor %}
