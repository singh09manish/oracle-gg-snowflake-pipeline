-- =================================================================
-- GoldenGate 19c Classic Replicat: {{ group.rds_replicat_name }}
-- Target: Oracle RDS (live mirror replication)
-- Tables: {{ group.rds_tables | length }}  Schemas: {{ group.rds_target_schemas | join(', ') }}
-- Generated by: python3 -m app.main generate
-- =================================================================

REPLICAT {{ group.rds_replicat_name }}
USERIDALIAS {{ target_rds_alias }}

{% if encryption_enabled -%}
-- Decrypt extract trail (encrypted at source)
DECRYPTTRAIL {{ encryption_algorithm }}
{% endif -%}

-- Discard file for rejected records
DISCARDFILE ./dirrpt/{{ group.rds_replicat_name }}.dsc, APPEND, MEGABYTES 500

{% if batch_sql -%}
-- Batch SQL for bulk apply performance
BATCHSQL BATCHTRANSOPS {{ grouptransops }}, OPSPERBATCH {{ batch_sql_buffer_size }}
{% endif -%}

GROUPTRANSOPS {{ grouptransops }}
MAXTRANSOPS {{ maxtransops }}

-- Monitoring
REPORTCOUNT EVERY 30 MINUTES, RATE

-- Table mappings (live mirror — standard replication, not INSERTALLRECORDS)
{% for t in group.rds_tables %}
MAP {{ t.schema }}.{{ t.name }}, TARGET {{ t.rds_target_schema }}.{{ t.name }}{% if t.excluded_columns %}, &
COLSEXCEPT ({{ t.excluded_columns | join(', ') }}){% endif %};
{% endfor %}
