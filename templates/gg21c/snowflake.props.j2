# =================================================================
# GoldenGate BigData 21c — Snowflake JDBC Event Handler
# Replicat: {{ group.replicat_name }}
# Tables:   {{ group.table_count }}
# Auth:     {{ snowflake_auth_method | default('password') }}
# Generated by: ggctl generate
# =================================================================

# ---------------------------------------------------------------
# Handler registration
# ---------------------------------------------------------------
gg.handlerlist=snowflake

# ---------------------------------------------------------------
# JDBC driver and connection
# ---------------------------------------------------------------
gg.handler.snowflake.type=jdbc
gg.handler.snowflake.DriverClass=net.snowflake.client.jdbc.SnowflakeDriver

# Connection URL — TLS 1.2+ enforced by default (encrypted in transit)
{% if snowflake_auth_method == 'keypair' %}
gg.handler.snowflake.connectionURL=jdbc:snowflake://{{ snowflake_account }}.snowflakecomputing.com/?warehouse={{ snowflake_warehouse }}&db={{ snowflake_database }}&schema={{ group.default_target_schema }}&role={{ snowflake_role }}&authenticator=snowflake_jwt&ssl=on
{% else %}
gg.handler.snowflake.connectionURL=jdbc:snowflake://{{ snowflake_account }}.snowflakecomputing.com/?warehouse={{ snowflake_warehouse }}&db={{ snowflake_database }}&schema={{ group.default_target_schema }}&role={{ snowflake_role }}&ssl=on
{% endif %}

# ---------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------
{% if snowflake_auth_method == 'keypair' %}
# Key Pair Authentication (PKCS8 private key)
gg.handler.snowflake.userName={{ snowflake_user }}
gg.handler.snowflake.privateKeyFile={{ snowflake_private_key_file }}
{% if snowflake_private_key_passphrase %}
gg.handler.snowflake.privateKeyFilePwd={{ snowflake_private_key_passphrase }}
{% endif %}
{% else %}
# Password Authentication (injected via environment variables)
gg.handler.snowflake.userName=${SNOWFLAKE_USER}
gg.handler.snowflake.password=${SNOWFLAKE_PASSWORD}
{% endif %}

# ---------------------------------------------------------------
# CDC operation mode — INSERTALLRECORDS
# All operations (insert/update/delete) are appended as inserts
# to a staging table. Downstream Snowflake tasks/streams handle
# MERGE/SCD logic.
# ---------------------------------------------------------------
gg.handler.snowflake.mode=op
gg.handler.snowflake.insertOpMode=insert
gg.handler.snowflake.updateOpMode=insert
gg.handler.snowflake.deleteOpMode=insert

# ---------------------------------------------------------------
# Include GG header info (op timestamp for CDC ordering)
# ---------------------------------------------------------------
gg.handler.snowflake.includeOpTimestamp=true

# ---------------------------------------------------------------
# Performance tuning
# ---------------------------------------------------------------
gg.handler.snowflake.maxOperations=10000
gg.handler.snowflake.flushOnCDCOperation=false

# ---------------------------------------------------------------
# Connection resilience
# ---------------------------------------------------------------
gg.handler.snowflake.connectionTimeout=30000
gg.handler.snowflake.queryTimeout=300000

# ---------------------------------------------------------------
# GG Java writer (required by BigData handler framework)
# ---------------------------------------------------------------
goldengate.userexit.timestamp=utc
goldengate.userexit.writers=javawriter
javawriter.stats.display=TRUE
javawriter.stats.full=TRUE

# ---------------------------------------------------------------
# Logging
# ---------------------------------------------------------------
gg.log=log4j
gg.log.level=INFO
gg.report.time=30sec

# ---------------------------------------------------------------
# Classpath
# ---------------------------------------------------------------
gg.classpath={{ gg21c_home }}/dirprm/{{ snowflake_jdbc_jar }}:{{ gg21c_home }}/ggjava/ggjava.jar
