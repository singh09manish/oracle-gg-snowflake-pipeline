-- =================================================================
-- GoldenGate BigData 21c Replicat: {{ group.replicat_name }}
-- Target: Snowflake via JDBC handler (INSERTALLRECORDS + COLMAP)
-- Tables: {{ group.table_count }}  Schemas: {{ group.target_schemas | join(', ') }}
-- Generated by: python3 -m app.main generate
-- =================================================================

REPLICAT {{ group.replicat_name }}
TARGETDB LIBFILE libggjava.so SET property=dirprm/{{ group.replicat_name }}.properties
REPORTCOUNT EVERY 1 MINUTES, RATE
GROUPTRANSOPS {{ grouptransops }}
MAXTRANSOPS {{ maxtransops }}

{% for t in group.tables %}
MAP {{ t.schema }}.{{ t.name }}, TARGET {{ t.target_schema }}.{{ t.name }}, INSERTALLRECORDS, &
{% if t.excluded_columns %}
COLSEXCEPT ({{ t.excluded_columns | join(', ') }}), &
{% endif %}
COLMAP ( &
    OP_TYPE = @STREXT(@GETENV('GGHEADER', 'OPTYPE'), 1, 1), &
    OP_TS = @GETENV('GGHEADER', 'COMMITTIMESTAMP'), &
    IS_DELETED = @CASE(@STREXT(@GETENV('GGHEADER', 'OPTYPE'), 1, 1), 'D', 1, 0) &
);
{% endfor %}
