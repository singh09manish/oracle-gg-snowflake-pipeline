-- =================================================================
-- GoldenGate BigData 21c Replicat: {{ group.replicat_name }}
-- Target: Snowflake via JDBC handler
-- Tables: {{ group.table_count }}  Schemas: {{ group.target_schemas | join(', ') }}
-- Generated by: python3 -m app.main generate
-- =================================================================

REPLICAT {{ group.replicat_name }}

-- BigData handler properties (Snowflake JDBC)
TARGETDB LIBFILE libggjava.so SET property=dirprm/{{ group.replicat_name }}.props

-- Report progress every minute
REPORTCOUNT EVERY 1 MINUTES, RATE

-- Batch apply: commit to Snowflake every {{ grouptransops }} logical transactions
-- Tuning: reduce for strict ordering; increase for bulk throughput
GROUPTRANSOPS {{ grouptransops }}
MAXTRANSOPS {{ maxtransops }}

-- Discard file for rows that fail to apply (PK violations, type mismatches)
DISCARDFILE ./dirrpt/{{ group.replicat_name }}_discard.txt, APPEND, MEGABYTES 100

-- -----------------------------------------------------------------
-- MAP rules ({{ group.table_count }} tables)
-- -----------------------------------------------------------------
{% for t in group.tables %}
MAP {{ t.schema }}.{{ t.name }}, TARGET {{ t.target_schema }}.{{ t.name }};
{% endfor %}
