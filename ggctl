# Commands: update
# ---------------------------------------------------------------------------

cmd_update() {
    cd "$PIPELINE_HOME"
    echo -e "${BOLD}Updating from GitHub...${NC}"
    git pull origin main
    _activate_venv
    pip install -r requirements.txt -q
    echo -e "${GREEN}Updated successfully.${NC}"
}

# ---------------------------------------------------------------------------
# Commands: setup
# ---------------------------------------------------------------------------

cmd_setup() {
    cd "$PIPELINE_HOME"
    bash scripts/ec2_setup.sh
}

