# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

_load_state

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    use)        cmd_use "$@" ;;
    info)       cmd_info "$@" ;;
    ggsci)      cmd_ggsci "$@" ;;
    generate|gen) cmd_generate "$@" ;;
    deploy)     cmd_deploy "$@" ;;
    status)     cmd_status "$@" ;;
    disable)    cmd_disable "$@" ;;
    enable)     cmd_enable "$@" ;;
    tables)     cmd_tables "$@" ;;
    watch)      cmd_watch "$@" ;;
    diagnose)   cmd_diagnose "$@" ;;
    health)     cmd_health "$@" ;;
    lag)        cmd_lag "$@" ;;
    report)     cmd_report "$@" ;;
    trails)     cmd_trails "$@" ;;
    graph)      cmd_graph "$@" ;;
    recover)    cmd_recover "$@" ;;
    schema-check) cmd_schema_check "$@" ;;
    recon)      cmd_recon "$@" ;;
    diff)       cmd_diff "$@" ;;
    ddl)        cmd_ddl "$@" ;;
    archive)    cmd_archive "$@" ;;
    update)     cmd_update "$@" ;;
    setup)      cmd_setup "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}" >&2
        echo "Run 'ggctl help' for usage." >&2
        exit 1
        ;;
esac
