#!/usr/bin/env bash
# =============================================================================
# ggctl — Unified CLI for Oracle GoldenGate → Snowflake Pipeline
# =============================================================================
#
# Single command to manage the entire pipeline lifecycle:
#   environments, config generation, deployment, GG context switching,
#   table enable/disable, monitoring, and health checks.
#
# Usage:
#   ggctl <command> [options]
#
# Environment commands:
#   ggctl env list                    Show all available environments
#   ggctl env use <name>              Switch to an environment (dev/staging/prod)
#   ggctl env show                    Show current environment settings
#   ggctl env create <name>           Create a new environment profile
#
# GoldenGate context:
#   ggctl use 19c                     Switch to GG 19c (extract/pump operations)
#   ggctl use 21c                     Switch to GG 21c (replicat operations)
#   ggctl ggsci                       Open GGSCI in current GG context
#
# Pipeline commands:
#   ggctl generate                    Generate all .prm files from inventory
#   ggctl deploy 19c [--dry-run]      Deploy extract + pump configs
#   ggctl deploy 21c [--dry-run]      Deploy replicat configs
#   ggctl deploy all [--dry-run]      Deploy everything
#
# Table control:
#   ggctl disable <SCHEMA.TABLE> [-r reason]
#   ggctl enable  <SCHEMA.TABLE>
#   ggctl tables                      Show inventory status (enabled/disabled)
#
# Monitoring:
#   ggctl status                      Show all GG process status + lag
#   ggctl watch [--auto-disable]      Start real-time ABEND watcher
#   ggctl health                      Run health check
#   ggctl lag                         Show extract/replicat lag
#   ggctl report                      Print group assignment report
#
# Maintenance:
#   ggctl archive                     Archive old trail files
#   ggctl update                      Pull latest code from GitHub
#   ggctl setup                       Re-run EC2 setup
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve paths
# ---------------------------------------------------------------------------

# PIPELINE_HOME: directory where this script lives
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PIPELINE_HOME="${PIPELINE_HOME:-$SCRIPT_PATH}"

ENVS_DIR="$PIPELINE_HOME/envs"
STATE_FILE="$PIPELINE_HOME/.ggctl_state"
VENV_DIR="$PIPELINE_HOME/.venv"

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'  # No Color

# ---------------------------------------------------------------------------
# State management (persists current env + GG context across sessions)
# ---------------------------------------------------------------------------

_load_state() {
    export GG_CURRENT_ENV="${GG_CURRENT_ENV:-default}"
    export GG_CURRENT_CONTEXT="${GG_CURRENT_CONTEXT:-19c}"

    if [ -f "$STATE_FILE" ]; then
        source "$STATE_FILE"
    fi
}

_save_state() {
    cat > "$STATE_FILE" <<EOF
GG_CURRENT_ENV="$GG_CURRENT_ENV"
GG_CURRENT_CONTEXT="$GG_CURRENT_CONTEXT"
EOF
}

_load_env() {
    local env_file="$ENVS_DIR/${GG_CURRENT_ENV}.env"
    if [ -f "$env_file" ]; then
        source "$env_file"
    else
        echo -e "${RED}Environment '${GG_CURRENT_ENV}' not found: $env_file${NC}" >&2
        echo "Available environments: $(ls "$ENVS_DIR"/*.env 2>/dev/null | xargs -I{} basename {} .env | tr '\n' ' ')" >&2
        exit 1
    fi
}

_activate_venv() {
    if [ -f "$VENV_DIR/bin/activate" ]; then
        source "$VENV_DIR/bin/activate"
    fi
}

_current_gg_home() {
    case "$GG_CURRENT_CONTEXT" in
        19c) echo "${GG19C_HOME:-/u01/app/oracle/product/19c/oggcore_1}" ;;
        21c) echo "${GG21C_HOME:-/u01/app/oracle/product/21c/oggbd_1}" ;;
        *)   echo "UNKNOWN" ;;
    esac
}

_inventory_path() {
    echo "${TABLE_INVENTORY:-input/table_inventory.xlsx}"
}

_config_path() {
    echo "${PIPELINE_CONFIG:-config/pipeline.yaml}"
}

# ---------------------------------------------------------------------------
# Header
# ---------------------------------------------------------------------------

_header() {
    local gg_home=$(_current_gg_home)
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}  ggctl${NC} — GoldenGate Pipeline Control"
    echo -e "  env: ${GREEN}${GG_CURRENT_ENV}${NC}  |  context: ${YELLOW}GG ${GG_CURRENT_CONTEXT}${NC}  |  home: ${gg_home}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ---------------------------------------------------------------------------
# Commands: env
# ---------------------------------------------------------------------------

cmd_env() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list)
            echo -e "\n${BOLD}Available environments:${NC}"
            for f in "$ENVS_DIR"/*.env 2>/dev/null; do
                local name=$(basename "$f" .env)
                if [ "$name" == "$GG_CURRENT_ENV" ]; then
                    echo -e "  ${GREEN}● $name${NC}  (active)"
                else
                    echo -e "  ○ $name"
                fi
            done
            if [ ! -d "$ENVS_DIR" ] || [ -z "$(ls "$ENVS_DIR"/*.env 2>/dev/null)" ]; then
                echo -e "  ${RED}No environments found.${NC}"
                echo "  Run: ggctl env create dev"
            fi
            echo ""
            ;;

        use)
            local name="${1:-}"
            if [ -z "$name" ]; then
                echo "Usage: ggctl env use <name>" >&2
                exit 1
            fi
            if [ ! -f "$ENVS_DIR/${name}.env" ]; then
                echo -e "${RED}Environment '$name' not found.${NC}" >&2
                echo "Create it with: ggctl env create $name" >&2
                exit 1
            fi
            GG_CURRENT_ENV="$name"
            _save_state
            _load_env
            echo -e "${GREEN}Switched to environment: $name${NC}"
            _header
            ;;

        show)
            _load_env
            _header
            echo ""
            echo -e "${BOLD}Environment variables:${NC}"
            echo "  GG_ENV_NAME       = ${GG_ENV_NAME:-}"
            echo "  GG19C_HOME        = ${GG19C_HOME:-}"
            echo "  GG21C_HOME        = ${GG21C_HOME:-}"
            echo "  JAVA_HOME         = ${JAVA_HOME:-}"
            echo "  GG_SOURCE_ALIAS   = ${GG_SOURCE_ALIAS:-}"
            echo "  SNOWFLAKE_ACCOUNT = ${SNOWFLAKE_ACCOUNT:-}"
            echo "  SNOWFLAKE_DATABASE= ${SNOWFLAKE_DATABASE:-}"
            echo "  PIPELINE_CONFIG   = ${PIPELINE_CONFIG:-config/pipeline.yaml}"
            echo "  TABLE_INVENTORY   = ${TABLE_INVENTORY:-input/table_inventory.xlsx}"
            echo ""
            ;;

        create)
            local name="${1:-}"
            if [ -z "$name" ]; then
                echo "Usage: ggctl env create <name>" >&2
                exit 1
            fi
            local target="$ENVS_DIR/${name}.env"
            if [ -f "$target" ]; then
                echo -e "${YELLOW}Environment '$name' already exists: $target${NC}" >&2
                exit 1
            fi
            mkdir -p "$ENVS_DIR"
            cp "$ENVS_DIR/default.env" "$target" 2>/dev/null || \
                cp "$PIPELINE_HOME/scripts/ec2_setup.sh" /dev/null  # fallback

            # Update the env name in the new file
            sed -i "s/GG_ENV_NAME=\"default\"/GG_ENV_NAME=\"$name\"/" "$target" 2>/dev/null || true

            echo -e "${GREEN}Created environment: $target${NC}"
            echo "Edit it:  vi $target"
            echo "Use it:   ggctl env use $name"
            ;;

        *)
            echo "Unknown env command: $subcmd" >&2
            echo "Usage: ggctl env [list|use|show|create]" >&2
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Commands: use (GG context switch)
# ---------------------------------------------------------------------------

cmd_use() {
    local ctx="${1:-}"
    case "$ctx" in
        19c|19)
            GG_CURRENT_CONTEXT="19c"
            _save_state
            _load_env
            echo -e "${GREEN}Switched to GG 19c context${NC}"
            echo "  Home: ${GG19C_HOME:-not set}"
            echo "  Processes: Extract + Pump"
            ;;
        21c|21)
            GG_CURRENT_CONTEXT="21c"
            _save_state
            _load_env
            echo -e "${GREEN}Switched to GG 21c context${NC}"
            echo "  Home: ${GG21C_HOME:-not set}"
            echo "  Processes: Replicat → Snowflake"
            ;;
        *)
            echo "Usage: ggctl use [19c|21c]" >&2
            echo ""
            echo "Current context: GG $GG_CURRENT_CONTEXT"
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Commands: ggsci
# ---------------------------------------------------------------------------

cmd_ggsci() {
    _load_env
    local gg_home=$(_current_gg_home)

    if [ ! -f "$gg_home/ggsci" ]; then
        echo -e "${RED}ggsci not found at: $gg_home/ggsci${NC}" >&2
        exit 1
    fi

    echo -e "${BOLD}Opening GGSCI (GG ${GG_CURRENT_CONTEXT})${NC} — $gg_home"
    echo "Type 'exit' to return to ggctl"
    echo ""

    cd "$gg_home"
    export LD_LIBRARY_PATH="$gg_home/lib:${LD_LIBRARY_PATH:-}"
    if [ "$GG_CURRENT_CONTEXT" == "21c" ] && [ -n "${JAVA_HOME:-}" ]; then
        export JAVA_HOME
        export PATH="$JAVA_HOME/bin:$PATH"
    fi
    "$gg_home/ggsci"
}

# ---------------------------------------------------------------------------
# Commands: generate
# ---------------------------------------------------------------------------

cmd_generate() {
    _load_env
    _activate_venv
    _header

    local inv=$(_inventory_path)
    echo -e "\n${BOLD}Generating configs from: $inv${NC}\n"

    cd "$PIPELINE_HOME"
    python3 -m app.main generate --input "$inv" "$@"
}

# ---------------------------------------------------------------------------
# Commands: deploy
# ---------------------------------------------------------------------------

cmd_deploy() {
    _load_env
    local target="${1:-}"
    shift 2>/dev/null || true

    case "$target" in
        19c|19)
            _header
            echo -e "\n${BOLD}Deploying GG 19c (Extract + Pump)${NC}\n"
            cd "$PIPELINE_HOME"
            GG_HOME="${GG19C_HOME}" bash scripts/deploy_gg19c.sh "$@"
            ;;
        21c|21)
            _header
            echo -e "\n${BOLD}Deploying GG 21c (Replicat → Snowflake)${NC}\n"
            cd "$PIPELINE_HOME"
            GG_HOME="${GG21C_HOME}" bash scripts/deploy_gg21c.sh "$@"
            ;;
        all)
            _header
            echo -e "\n${BOLD}Deploying GG 19c + 21c${NC}\n"
            cd "$PIPELINE_HOME"
            GG_HOME="${GG19C_HOME}" bash scripts/deploy_gg19c.sh "$@"
            echo ""
            GG_HOME="${GG21C_HOME}" bash scripts/deploy_gg21c.sh "$@"
            ;;
        *)
            echo "Usage: ggctl deploy [19c|21c|all] [--dry-run]" >&2
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Commands: status
# ---------------------------------------------------------------------------

cmd_status() {
    _load_env
    _header

    echo ""

    # GG 19c status
    if [ -f "${GG19C_HOME}/ggsci" ]; then
        echo -e "${BOLD}GG 19c (Extract + Pump):${NC}"
        echo "INFO ALL" | "${GG19C_HOME}/ggsci" 2>/dev/null | grep -E "EXTRACT|PUMP|Program|Running|Stopped|Abended" || \
            echo "  Could not connect to GG 19c manager"
        echo ""
        echo -e "${BOLD}Extract Lag:${NC}"
        echo "LAG EXTRACT *" | "${GG19C_HOME}/ggsci" 2>/dev/null | grep -v "^$" || \
            echo "  Could not check lag"
    else
        echo -e "${YELLOW}GG 19c not found at: ${GG19C_HOME}${NC}"
    fi

    echo ""

    # GG 21c status
    if [ -f "${GG21C_HOME}/ggsci" ]; then
        echo -e "${BOLD}GG 21c (Replicat → Snowflake):${NC}"
        echo "INFO ALL" | "${GG21C_HOME}/ggsci" 2>/dev/null | grep -E "REPLICAT|Program|Running|Stopped|Abended" || \
            echo "  Could not connect to GG 21c manager"
        echo ""
        echo -e "${BOLD}Replicat Lag:${NC}"
        echo "LAG REPLICAT *" | "${GG21C_HOME}/ggsci" 2>/dev/null | grep -v "^$" || \
            echo "  Could not check lag"
    else
        echo -e "${YELLOW}GG 21c not found at: ${GG21C_HOME}${NC}"
    fi

    echo ""
}

# ---------------------------------------------------------------------------
# Commands: disable / enable / tables
# ---------------------------------------------------------------------------

cmd_disable() {
    _load_env
    _activate_venv

    local inv=$(_inventory_path)
    cd "$PIPELINE_HOME"
    python3 -m app.main disable --input "$inv" "$@"
}

cmd_enable() {
    _load_env
    _activate_venv

    local inv=$(_inventory_path)
    cd "$PIPELINE_HOME"
    python3 -m app.main enable --input "$inv" "$@"
}

cmd_tables() {
    _load_env
    _activate_venv
    _header

    local inv=$(_inventory_path)
    cd "$PIPELINE_HOME"
    python3 -m app.main status --input "$inv"
}

# ---------------------------------------------------------------------------
# Commands: watch (event watcher)
# ---------------------------------------------------------------------------

cmd_watch() {
    _load_env
    _activate_venv
    _header

    local gg_home=$(_current_gg_home)
    local inv=$(_inventory_path)

    echo -e "\n${BOLD}Starting ABEND Event Watcher${NC}"
    echo "  Watching: $gg_home/ggserr.log"
    echo "  Inventory: $inv"
    echo "  Press Ctrl+C to stop"
    echo ""

    cd "$PIPELINE_HOME"
    python3 scripts/event_watcher.py \
        --gg-home "$gg_home" \
        --inventory "$inv" \
        --config "$(_config_path)" \
        "$@"
}

# ---------------------------------------------------------------------------
# Commands: health
# ---------------------------------------------------------------------------

cmd_health() {
    _load_env
    _header

    cd "$PIPELINE_HOME"
    GG19C_HOME="${GG19C_HOME}" GG21C_HOME="${GG21C_HOME}" bash scripts/health_check.sh
}

# ---------------------------------------------------------------------------
# Commands: lag
# ---------------------------------------------------------------------------

cmd_lag() {
    _load_env
    _header

    echo ""
    echo -e "${BOLD}Extract Lag (GG 19c):${NC}"
    if [ -f "${GG19C_HOME}/ggsci" ]; then
        echo "LAG EXTRACT *" | "${GG19C_HOME}/ggsci" 2>/dev/null | grep -v "^GGSCI\|^$\|^Oracle\|^Version\|^Copyright" || \
            echo "  No extracts running"
    fi

    echo ""
    echo -e "${BOLD}Replicat Lag (GG 21c):${NC}"
    if [ -f "${GG21C_HOME}/ggsci" ]; then
        echo "LAG REPLICAT *" | "${GG21C_HOME}/ggsci" 2>/dev/null | grep -v "^GGSCI\|^$\|^Oracle\|^Version\|^Copyright" || \
            echo "  No replicats running"
    fi
    echo ""
}

# ---------------------------------------------------------------------------
# Commands: report
# ---------------------------------------------------------------------------

cmd_report() {
    _load_env
    _activate_venv

    local inv=$(_inventory_path)
    cd "$PIPELINE_HOME"
    python3 -m app.main report --input "$inv" "$@"
}

# ---------------------------------------------------------------------------
# Commands: archive
# ---------------------------------------------------------------------------

cmd_archive() {
    _load_env
    _header

    cd "$PIPELINE_HOME"
    GG19C_HOME="${GG19C_HOME}" GG21C_HOME="${GG21C_HOME}" bash scripts/archive_trails.sh "$@"
}

# ---------------------------------------------------------------------------
# Commands: update
# ---------------------------------------------------------------------------

cmd_update() {
    cd "$PIPELINE_HOME"
    echo -e "${BOLD}Updating from GitHub...${NC}"
    git pull origin main
    _activate_venv
    pip install -r requirements.txt -q
    echo -e "${GREEN}Updated successfully.${NC}"
}

# ---------------------------------------------------------------------------
# Commands: setup
# ---------------------------------------------------------------------------

cmd_setup() {
    cd "$PIPELINE_HOME"
    bash scripts/ec2_setup.sh
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

cmd_help() {
    echo -e "
${BOLD}ggctl${NC} — GoldenGate Pipeline Control CLI

${CYAN}Environment:${NC}
  ggctl env list                    Show available environments
  ggctl env use <name>              Switch environment (dev/staging/prod)
  ggctl env show                    Show current environment settings
  ggctl env create <name>           Create a new environment profile

${CYAN}GoldenGate Context:${NC}
  ggctl use 19c                     Switch to GG 19c (extract/pump)
  ggctl use 21c                     Switch to GG 21c (replicat/snowflake)
  ggctl ggsci                       Open GGSCI in current context

${CYAN}Pipeline:${NC}
  ggctl generate                    Generate .prm files from inventory
  ggctl deploy 19c [--dry-run]      Deploy extract + pump
  ggctl deploy 21c [--dry-run]      Deploy replicat
  ggctl deploy all [--dry-run]      Deploy everything

${CYAN}Table Control:${NC}
  ggctl disable -t SCHEMA.TABLE [-r reason]
  ggctl enable  -t SCHEMA.TABLE
  ggctl tables                      Show enabled/disabled status

${CYAN}Monitoring:${NC}
  ggctl status                      All GG processes + lag
  ggctl watch [--auto-disable]      Real-time ABEND watcher
  ggctl health                      Run health check
  ggctl lag                         Show lag only
  ggctl report                      Group assignment report

${CYAN}Maintenance:${NC}
  ggctl archive                     Archive old trail files
  ggctl update                      Pull latest code from GitHub
  ggctl setup                       Re-run EC2 setup

${CYAN}Examples:${NC}
  ggctl env use prod                # Switch to production
  ggctl use 19c                     # Work with GG 19c
  ggctl generate                    # Generate all configs
  ggctl deploy all --dry-run        # Preview deployment
  ggctl deploy all                  # Deploy everything
  ggctl status                      # Check all processes
  ggctl disable -t HR.EMPLOYEES -r 'missing PK'
  ggctl generate                    # Regenerate (table excluded)
  ggctl watch --auto-disable        # Auto-handle ABENDs
"
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

_load_state

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    env)        cmd_env "$@" ;;
    use)        cmd_use "$@" ;;
    ggsci)      cmd_ggsci "$@" ;;
    generate|gen) cmd_generate "$@" ;;
    deploy)     cmd_deploy "$@" ;;
    status)     cmd_status "$@" ;;
    disable)    cmd_disable "$@" ;;
    enable)     cmd_enable "$@" ;;
    tables)     cmd_tables "$@" ;;
    watch)      cmd_watch "$@" ;;
    health)     cmd_health "$@" ;;
    lag)        cmd_lag "$@" ;;
    report)     cmd_report "$@" ;;
    archive)    cmd_archive "$@" ;;
    update)     cmd_update "$@" ;;
    setup)      cmd_setup "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}" >&2
        echo "Run 'ggctl help' for usage." >&2
        exit 1
        ;;
esac
