#!/usr/bin/env bash
# =============================================================================
# ggctl — Unified CLI for Oracle GoldenGate → Snowflake Pipeline
# =============================================================================
#
# Single command to manage the entire pipeline lifecycle on an EC2 instance:
#   config generation, deployment, GG 19c/21c context switching,
#   table enable/disable, monitoring, and health checks.
#
# Each EC2 instance has its own copy of this project (via scp or git clone).
# Edit config/pipeline.yaml for that instance's GG paths and Snowflake config.
#
# Usage:
#   ggctl <command> [options]
#
# GoldenGate context:
#   ggctl use 19c                     Switch to GG 19c (extract/pump)
#   ggctl use 21c                     Switch to GG 21c (replicat)
#   ggctl ggsci                       Open GGSCI in current GG context
#   ggctl info                        Show current config + GG paths
#
# Pipeline commands:
#   ggctl generate                    Generate all .prm files from inventory
#   ggctl deploy 19c [--dry-run]      Deploy extract + pump configs
#   ggctl deploy 21c [--dry-run]      Deploy replicat configs
#   ggctl deploy all [--dry-run]      Deploy everything
#
# Table control:
#   ggctl disable -t SCHEMA.TABLE [-r reason]
#   ggctl enable  -t SCHEMA.TABLE
#   ggctl tables                      Show inventory status (enabled/disabled)
#
# Monitoring:
#   ggctl status                      Show all GG process status + lag
#   ggctl watch [--auto-disable]      Start real-time ABEND watcher
#   ggctl health                      Run health check
#   ggctl diagnose                    Diagnose lag / data not flowing
#   ggctl lag                         Show extract/replicat lag
#   ggctl report                      Print group assignment report
#   ggctl trails [--once|--watch]     Trail file size monitor
#   ggctl graph [--format text|dot|html]  Pipeline dependency graph
#
# Recovery & Schema Evolution:
#   ggctl recover [options]             Start auto-recovery daemon
#   ggctl schema-check --current-csv FILE [options]
#                                       Detect schema drift and generate ALTERs
#
# Maintenance:
#   ggctl archive                     Archive old trail files
#   ggctl update                      Pull latest code from GitHub
#   ggctl setup                       Re-run EC2 setup
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve paths
# ---------------------------------------------------------------------------

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PIPELINE_HOME="${PIPELINE_HOME:-$SCRIPT_PATH}"

CONFIG_FILE="$PIPELINE_HOME/config/pipeline.yaml"
STATE_FILE="$PIPELINE_HOME/.ggctl_state"
VENV_DIR="$PIPELINE_HOME/.venv"
INVENTORY="$PIPELINE_HOME/input/table_inventory.xlsx"

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# State management (persists GG context across sessions)
# ---------------------------------------------------------------------------

_load_state() {
    export GG_CURRENT_CONTEXT="${GG_CURRENT_CONTEXT:-19c}"
    if [ -f "$STATE_FILE" ]; then
        source "$STATE_FILE"
    fi
}

_save_state() {
    echo "GG_CURRENT_CONTEXT=\"$GG_CURRENT_CONTEXT\"" > "$STATE_FILE"
}

# ---------------------------------------------------------------------------
# Read GG homes from pipeline.yaml (no env files needed)
# ---------------------------------------------------------------------------

_read_yaml_value() {
    # Simple YAML value reader — no external deps needed
    local key="$1"
    grep -E "^\s*${key}:" "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*:\s*//' | tr -d '"' | tr -d "'"
}

_gg19c_home() {
    _read_yaml_value "home" | head -1
    # Fallback: parse more specifically
    python3 -c "
import yaml
with open('$CONFIG_FILE') as f:
    c = yaml.safe_load(f)
print(c.get('gg19c', {}).get('home', '/u01/app/oracle/product/19c/oggcore_1'))
" 2>/dev/null || echo "/u01/app/oracle/product/19c/oggcore_1"
}

_gg21c_home() {
    python3 -c "
import yaml
with open('$CONFIG_FILE') as f:
    c = yaml.safe_load(f)
print(c.get('gg21c', {}).get('home', '/u01/app/oracle/product/21c/oggbd_1'))
" 2>/dev/null || echo "/u01/app/oracle/product/21c/oggbd_1"
}

_java_home() {
    python3 -c "
import yaml
with open('$CONFIG_FILE') as f:
    c = yaml.safe_load(f)
print(c.get('gg21c', {}).get('java_home', ''))
" 2>/dev/null || echo ""
}

_current_gg_home() {
    case "$GG_CURRENT_CONTEXT" in
        19c) _gg19c_home ;;
        21c) _gg21c_home ;;
        *)   echo "UNKNOWN" ;;
    esac
}

_activate_venv() {
    if [ -f "$VENV_DIR/bin/activate" ]; then
        source "$VENV_DIR/bin/activate"
    fi
}

# ---------------------------------------------------------------------------
# Header
# ---------------------------------------------------------------------------

_header() {
    local gg_home=$(_current_gg_home)
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}  ggctl${NC} — GoldenGate Pipeline Control"
    echo -e "  context: ${YELLOW}GG ${GG_CURRENT_CONTEXT}${NC}  |  home: ${gg_home}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ---------------------------------------------------------------------------
# Commands: use (GG context switch)
# ---------------------------------------------------------------------------

cmd_use() {
    local ctx="${1:-}"
    case "$ctx" in
        19c|19)
            GG_CURRENT_CONTEXT="19c"
            _save_state
            local home=$(_gg19c_home)
            echo -e "${GREEN}Switched to GG 19c context${NC}"
            echo "  Home: $home"
            echo "  Processes: Extract + Pump"
            ;;
        21c|21)
            GG_CURRENT_CONTEXT="21c"
            _save_state
            local home=$(_gg21c_home)
            echo -e "${GREEN}Switched to GG 21c context${NC}"
            echo "  Home: $home"
            echo "  Processes: Replicat → Snowflake"
            ;;
        *)
            echo "Usage: ggctl use [19c|21c]" >&2
            echo ""
            echo "Current context: GG $GG_CURRENT_CONTEXT ($(_current_gg_home))"
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Commands: info (show current config)
# ---------------------------------------------------------------------------

cmd_info() {
    _header
    echo ""
    echo -e "${BOLD}Pipeline Config:${NC}  $CONFIG_FILE"
    echo -e "${BOLD}Inventory:${NC}        $INVENTORY"
    echo ""
    echo -e "${BOLD}GoldenGate Paths:${NC}"
    echo "  GG 19c Home:    $(_gg19c_home)"
    echo "  GG 21c Home:    $(_gg21c_home)"
    echo "  Java Home:      $(_java_home)"
    echo ""

    _activate_venv
    python3 -c "
import yaml
with open('$CONFIG_FILE') as f:
    c = yaml.safe_load(f)
sf = c.get('gg21c', {}).get('snowflake', {})
print('Snowflake Target:')
print(f'  Account:        {sf.get(\"account\", \"not set\")}')
print(f'  Database:       {sf.get(\"database\", \"not set\")}')
print(f'  Warehouse:      {sf.get(\"warehouse\", \"not set\")}')
print(f'  Role:           {sf.get(\"role\", \"not set\")}')
enc = c.get('gg19c', {}).get('trail', {}).get('encryption', {})
print(f'')
print(f'Encryption:       {\"AES256 (enabled)\" if enc.get(\"enabled\") else \"disabled\"} ')
" 2>/dev/null || true
    echo ""
}

# ---------------------------------------------------------------------------
# Commands: ggsci
# ---------------------------------------------------------------------------

cmd_ggsci() {
    local gg_home=$(_current_gg_home)

    if [ ! -f "$gg_home/ggsci" ]; then
        echo -e "${RED}ggsci not found at: $gg_home/ggsci${NC}" >&2
        exit 1
    fi

    echo -e "${BOLD}Opening GGSCI (GG ${GG_CURRENT_CONTEXT})${NC} — $gg_home"
    echo "Type 'exit' to return to ggctl"
    echo ""

    cd "$gg_home"
    export LD_LIBRARY_PATH="$gg_home/lib:${LD_LIBRARY_PATH:-}"
    local jh=$(_java_home)
    if [ "$GG_CURRENT_CONTEXT" == "21c" ] && [ -n "$jh" ]; then
        export JAVA_HOME="$jh"
        export PATH="$JAVA_HOME/bin:$PATH"
    fi
    "$gg_home/ggsci"
}

# ---------------------------------------------------------------------------
# Commands: generate
# ---------------------------------------------------------------------------

cmd_generate() {
    _activate_venv
    _header

    echo -e "\n${BOLD}Generating configs from: $INVENTORY${NC}\n"

    cd "$PIPELINE_HOME"
    python3 -m app.main generate --input "$INVENTORY" "$@"
}

# ---------------------------------------------------------------------------
# Commands: deploy
# ---------------------------------------------------------------------------

cmd_deploy() {
    local target="${1:-}"
    shift 2>/dev/null || true

    local gg19=$(_gg19c_home)
    local gg21=$(_gg21c_home)

    case "$target" in
        19c|19)
            _header
            echo -e "\n${BOLD}Deploying GG 19c (Extract + Pump)${NC}\n"
            cd "$PIPELINE_HOME"
            GG_HOME="$gg19" bash scripts/deploy_gg19c.sh "$@"
            ;;
        21c|21)
            _header
            echo -e "\n${BOLD}Deploying GG 21c (Replicat → Snowflake)${NC}\n"
            cd "$PIPELINE_HOME"
            GG_HOME="$gg21" bash scripts/deploy_gg21c.sh "$@"
            ;;
        all)
            _header
            echo -e "\n${BOLD}Deploying GG 19c + 21c${NC}\n"
            cd "$PIPELINE_HOME"
            GG_HOME="$gg19" bash scripts/deploy_gg19c.sh "$@"
            echo ""
            GG_HOME="$gg21" bash scripts/deploy_gg21c.sh "$@"
            ;;
        *)
            echo "Usage: ggctl deploy [19c|21c|all] [--dry-run]" >&2
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Commands: status
# ---------------------------------------------------------------------------

cmd_status() {
    _header

    local gg19=$(_gg19c_home)
    local gg21=$(_gg21c_home)

    echo ""

    # GG 19c status
    if [ -f "$gg19/ggsci" ]; then
        echo -e "${BOLD}GG 19c (Extract + Pump):${NC}"
        echo "INFO ALL" | "$gg19/ggsci" 2>/dev/null | grep -E "EXTRACT|PUMP|Program|Running|Stopped|Abended" || \
            echo "  Could not connect to GG 19c manager"
        echo ""
        echo -e "${BOLD}Extract Lag:${NC}"
        echo "LAG EXTRACT *" | "$gg19/ggsci" 2>/dev/null | grep -v "^$" || \
            echo "  Could not check lag"
    else
        echo -e "${YELLOW}GG 19c not found at: $gg19${NC}"
    fi

    echo ""

    # GG 21c status
    if [ -f "$gg21/ggsci" ]; then
        echo -e "${BOLD}GG 21c (Replicat → Snowflake):${NC}"
        echo "INFO ALL" | "$gg21/ggsci" 2>/dev/null | grep -E "REPLICAT|Program|Running|Stopped|Abended" || \
            echo "  Could not connect to GG 21c manager"
        echo ""
        echo -e "${BOLD}Replicat Lag:${NC}"
        echo "LAG REPLICAT *" | "$gg21/ggsci" 2>/dev/null | grep -v "^$" || \
            echo "  Could not check lag"
    else
        echo -e "${YELLOW}GG 21c not found at: $gg21${NC}"
    fi

    echo ""
}

# ---------------------------------------------------------------------------
# Commands: disable / enable / tables
# ---------------------------------------------------------------------------

cmd_disable() {
    _activate_venv
    cd "$PIPELINE_HOME"
    python3 -m app.main disable --input "$INVENTORY" "$@"
}

cmd_enable() {
    _activate_venv
    cd "$PIPELINE_HOME"
    python3 -m app.main enable --input "$INVENTORY" "$@"
}

cmd_tables() {
    _activate_venv
    _header
    cd "$PIPELINE_HOME"
    python3 -m app.main status --input "$INVENTORY"
}

# ---------------------------------------------------------------------------
# Commands: watch (event watcher)
# ---------------------------------------------------------------------------

cmd_watch() {
    _activate_venv
    _header

    local gg_home=$(_current_gg_home)

    echo -e "\n${BOLD}Starting ABEND Event Watcher${NC}"
    echo "  Watching: $gg_home/ggserr.log"
    echo "  Inventory: $INVENTORY"
    echo "  Press Ctrl+C to stop"
    echo ""

    cd "$PIPELINE_HOME"
    python3 scripts/event_watcher.py \
        --gg-home "$gg_home" \
        --inventory "$INVENTORY" \
        --config "$CONFIG_FILE" \
        "$@"
}

# ---------------------------------------------------------------------------
# Commands: diagnose (lag diagnostic)
# ---------------------------------------------------------------------------

cmd_diagnose() {
    _header
    echo -e "\n${BOLD}Running Pipeline Lag Diagnostic${NC}\n"
    cd "$PIPELINE_HOME"
    GG19C_HOME="$(_gg19c_home)" GG21C_HOME="$(_gg21c_home)" bash scripts/diagnose_lag.sh
}

# ---------------------------------------------------------------------------
# Commands: health
# ---------------------------------------------------------------------------

cmd_health() {
    _header
    cd "$PIPELINE_HOME"
    GG19C_HOME="$(_gg19c_home)" GG21C_HOME="$(_gg21c_home)" bash scripts/health_check.sh
}

# ---------------------------------------------------------------------------
# Commands: lag
# ---------------------------------------------------------------------------

cmd_lag() {
    _header

    local gg19=$(_gg19c_home)
    local gg21=$(_gg21c_home)

    echo ""
    echo -e "${BOLD}Extract Lag (GG 19c):${NC}"
    if [ -f "$gg19/ggsci" ]; then
        echo "LAG EXTRACT *" | "$gg19/ggsci" 2>/dev/null | grep -v "^GGSCI\|^$\|^Oracle\|^Version\|^Copyright" || \
            echo "  No extracts running"
    fi

    echo ""
    echo -e "${BOLD}Replicat Lag (GG 21c):${NC}"
    if [ -f "$gg21/ggsci" ]; then
        echo "LAG REPLICAT *" | "$gg21/ggsci" 2>/dev/null | grep -v "^GGSCI\|^$\|^Oracle\|^Version\|^Copyright" || \
            echo "  No replicats running"
    fi
    echo ""
}

