# =============================================================================
# GoldenGate Pipeline — Environment Profile (TEMPLATE)
# =============================================================================
#
# This is the default template. For each environment, copy this file:
#
#   cp envs/default.env envs/dev.env
#   cp envs/default.env envs/staging.env
#   cp envs/default.env envs/prod.env
#
# Then edit the copy with environment-specific values.
#
# Activate with:  ggctl env use dev
# =============================================================================

# Environment name (used in logging, alerts, and GG process naming)
GG_ENV_NAME="default"

# ---------------------------------------------------------------------------
# GoldenGate Paths
# ---------------------------------------------------------------------------

# GG 19c Classic home (Extract + Pump)
GG19C_HOME="/u01/app/oracle/product/19c/oggcore_1"

# GG 21c BigData home (Replicat → Snowflake via JDBC)
GG21C_HOME="/u01/app/oracle/product/21c/oggbd_1"

# Java home for GG 21c
JAVA_HOME="/usr/lib/jvm/java-11-openjdk-11.0.25.0.9-2.el8.x86_64"

# ---------------------------------------------------------------------------
# Oracle Source
# ---------------------------------------------------------------------------

# GG credential store alias (must match: ggsci> ADD CREDENTIALSTORE ... ALIAS)
GG_SOURCE_ALIAS="rdsadmin"

# ---------------------------------------------------------------------------
# Snowflake Target
# ---------------------------------------------------------------------------

SNOWFLAKE_ACCOUNT="your_account"          # e.g. xy12345.us-east-1
SNOWFLAKE_WAREHOUSE="YOUR_WH"
SNOWFLAKE_DATABASE="YOUR_DB"
SNOWFLAKE_ROLE="GG_ROLE"

# IMPORTANT: Never store passwords here. Use one of:
#   export SNOWFLAKE_USER=xxx SNOWFLAKE_PASSWORD=xxx  (session env vars)
#   AWS Secrets Manager (recommended)

# ---------------------------------------------------------------------------
# Pipeline Config
# ---------------------------------------------------------------------------

# Which pipeline.yaml to use (relative to PIPELINE_HOME)
# For env-specific overrides, create config/pipeline-dev.yaml etc.
PIPELINE_CONFIG="config/pipeline.yaml"

# Which inventory to use (relative to PIPELINE_HOME)
TABLE_INVENTORY="input/table_inventory.xlsx"
